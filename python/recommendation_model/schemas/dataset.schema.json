{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mini-OneRec-MVP SFT row",
  "type": "object",
  "required": [
    "schema_version",
    "sample_id",
    "task_type",
    "prompt",
    "target_topic_id",
    "target_topic_token"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "sample_id": {"type": "string", "minLength": 1},
    "scenario_id": {"type": ["string", "null"]},
    "scenario_group_id": {"type": ["string", "null"]},
    "task_type": {"enum": ["next_topic", "topic_to_sid"]},
    "position": {"type": ["integer", "null"], "minimum": 1, "maximum": 3},
    "prompt": {"type": "string", "minLength": 1},
    "target_topic_id": {"type": "string", "minLength": 1},
    "target_topic_token": {"type": "string", "pattern": "^<MED_TOPIC_[0-9]{4,}>$"},
    "candidate_topic_ids": {"type": "array", "items": {"type": "string"}},
    "selected_topic_ids": {"type": "array", "items": {"type": "string"}},
    "history": {"type": "array", "items": {"type": "object"}},
    "target_source": {"type": "string"}
  },
  "additionalProperties": true
}
