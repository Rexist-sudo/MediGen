# DeepSeek LLM (default runtime)
LLM_BACKEND=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=90
DEEPSEEK_MAX_RETRIES=1
DEEPSEEK_MAX_TOKENS=2048

# Analysis behavior
RECOMMENDATION_ENABLED=true
RECOMMENDATION_TOP_K=3
RECOMMENDATION_TOPIC_PATH=./data/recommendation/knowledge_topics.jsonl
MAX_HISTORY_INTERACTIONS=20
PROTOTYPE_REJECT_OBVIOUS_PHI=true
RECOMMENDATION_GENERATE_CONTENT=true
INFRASTRUCTURE_REQUIRED=true

# Application
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Local infrastructure used by /clinical/analyze
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=clinical_decision
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpass
NEO4J_DATABASE=neo4j
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DATABASE=0
REDIS_CACHE_TTL_SECONDS=1800
RATE_LIMIT_REQUESTS_PER_MINUTE=20
FHIR_SERVER_URL=http://localhost:8080/fhir
FHIR_TIMEOUT_SECONDS=30
HAPI_IMAGE=medigen/hapi-fhir:v8.10.0-3
